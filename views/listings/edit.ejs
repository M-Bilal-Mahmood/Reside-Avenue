<%layout("layouts/boilerplate")%>
<% block('styles').append('<link rel="stylesheet" href="/css/edit.css">') %>
<%-block('scripts').append('<script src="/js/edit.js"></script>')%>
<main>
    <div class="form_wrapper">
        <div class="form_header">
            <span>Property  Details</span>
            <p>Share the basics about your space — you can always update these later.</p>
        </div>
        <form action="/listings/<%= listingDetails._id %>?_method=PUT" method="POST" class="needs-validation" novalidate enctype="multipart/form-data">
            <div class="form_field_wrapper">
                <label for="title">Title</label>
                <input type="text" value="<%= listingDetails.title %>" name="title" required>
                <div class="invalid-feedback">Please enter a title.</div>
                <div class="valid-feedback">Looks good!</div>
            </div>
            <div class="form_field_wrapper">
                <label for="description">Description</label>
                <textarea type="text" name="description" required><%= listingDetails.description %></textarea>
                <div class="invalid-feedback">Please enter a description.</div>
                <div class="valid-feedback">Noted it!</div>
            </div>
            <div class="form_field_wrapper">
                <label>Upload Image</label>
                <div class="upload-wrapper">

                    <div class="upload-thumb">
                        <img src="<%= listingDetails.image.url %>" alt="current image" />
                    </div>

                    <div class="upload-info">
                        <p class="upload-filename">Current image shown — choose to replace</p>
                        <p class="upload-hint">PNG, JPG, WEBP — max 5MB</p>
                        <label for="image" class="upload-choose-btn">
                            <i class="fa-solid fa-upload"></i>
                            Change file
                        </label>
                    </div>

                    <input type="file" id="image" name="image" accept="image/*" />

                </div>
            </div>
            <div class="form_field_wrapper">
                <label for="price">Price per night</label>
                <input type="number" value="<%= listingDetails.price %>" placeholder="Enter your price" name="price" required>
                <div class="invalid-feedback">Please enter a price.</div>
                <div class="valid-feedback">Bold choice!</div>
            </div>
            <div class="form_field_wrapper" id="form_field_location_wrapper">
                <div class="location_field">
                    <label for="location">Location</label>
                    <input type="text" value="<%= listingDetails.location %>" placeholder="City or area" name="location" required>
                    <div class="invalid-feedback">Please enter a location.</div>
                    <div class="valid-feedback">Found it!</div>
                </div>
                <div class="location_field">
                    <label for="country">Country</label>
                    <input type="text" value="<%= listingDetails.country %>" placeholder="Country" name="country" required>
                    <div class="invalid-feedback">Please enter a country.</div>
                    <div class="valid-feedback">Acceptable choice!</div>
                </div>
            </div>
            <button type="submit">Update Listing</button>
        </form>
    </div>
</main>    